+    return params.cmesh_stage_layer_start >= 0 &&
+           params.cmesh_stage_layer_end >= params.cmesh_stage_layer_start &&
+           params.cmesh_stage_layer_end < (int32_t) hparams.n_layer_all;
+}
+
+int llama_model::cmesh_stage_layer_start() const {
+    return params.cmesh_stage_layer_start;
+}
+
+int llama_model::cmesh_stage_layer_end() const {
+    return params.cmesh_stage_layer_end;
+}
+
+bool llama_model::cmesh_stage_first() const {
+    return cmesh_stage_enabled() && params.cmesh_stage_layer_start == 0;
+}
+
+bool llama_model::cmesh_stage_terminal() const {
+    return cmesh_stage_enabled() && params.cmesh_stage_layer_end == (int32_t) hparams.n_layer_all - 1;
+}
